# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build
/.next/
/out/
/build/
dist/

# Production
build/

# Env vars (NEVER commit these — credentials live here)
.env
.env*.local
.env.local

# Editor / OS
.DS_Store
*.swp
*.swo
.vscode/
.idea/
*.pem

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Claude Code local config (contains wizard token)
.claude/settings.local.json

# Vercel
.vercel/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Testing
/coverage/

# Supabase CLI local state
supabase/.temp/
supabase/.branches/

# Temporary backup
.gitignore.bak
.vercel
