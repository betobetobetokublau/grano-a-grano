# Plantilla de variables de entorno para grano-a-grano.
# Copia este archivo a .env.local y rellena con tus credenciales reales.
# .env.local NUNCA se commitea (esta en .gitignore).

# NEXT_PUBLIC_SUPABASE_URL — Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=

# NEXT_PUBLIC_SUPABASE_ANON_KEY — Supabase Dashboard > Settings > API > Project API keys > anon/publishable
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# DATABASE_URL — Supabase Dashboard > Settings > Database > Connection string > URI
# Solo se usa para migrations y scripts de servidor. Nunca expuesta al browser.
DATABASE_URL=
